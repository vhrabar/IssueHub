<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.github.vhrabar.issuehub</id>
    <name>IssueHub</name>
    <vendor>vhrabar</vendor>
    <description><![CDATA[
        <p><b>IssueHub</b> brings your GitHub issues into the IDE. Browse, filter, and open issues for the
        current repository from a dedicated tool window, without leaving your editor.</p>
        <ul>
            <li>List open and closed issues for the configured repository</li>
            <li>Inspect issue details, labels, and assignees</li>
            <li>Open any issue in the browser with a click</li>
        </ul>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <resource-bundle>messages.IssueHubBundle</resource-bundle>

    <extensionPoints>
        <extensionPoint
            name="issueProvider"
            interface="com.github.vhrabar.issuehub.provider.IssueProvider"
            dynamic="true"/>
    </extensionPoints>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow
            id="IssueHub"
            anchor="left"
            factoryClass="com.github.vhrabar.issuehub.toolWindow.IssueHubToolWindowFactory"/>
    </extensions>

    <extensions defaultExtensionNs="com.github.vhrabar.issuehub">
        <issueProvider implementation="com.github.vhrabar.issuehub.provider.github.GitHubIssueProvider"/>
    </extensions>
</idea-plugin>